{% schema %}
{
  "name": "Slideshow",
  "class": "slide-show-main",
  "settings": [
    {
      "type": "text",
      "label": "Section Class",
      "id": "section_class"
    },
    {
      "type": "color_scheme",
      "label": "Colour Scheme",
      "id": "colour_scheme"
    },
    {
      "type": "checkbox",
      "label": "Show Navigation",
      "id": "show_navigation",
      "default": true
    },
    {
      "type": "checkbox",
      "label": "Auto Rotate Slideshow",
      "id": "auto_rotate_slideshow",
      "default": true
    },
    {
      "type": "range",
      "label": "Change Slides Every",
      "id": "change_slides_every",
      "default": 3,
      "min": 1,
      "max": 10,
      "step": 1
    }
  ],
  "blocks": [
    {
      "type": "image_block",
      "name": "Image Block",
      "settings": [
        {
          "type": "image_picker",
          "label": "Desktop Image",
          "id": "desktop_image"
        },
        {
          "type": "image_picker",
          "label": "Mobile Image",
          "id": "mobile_image"
        },
        {
          "type": "select",
          "id": "desktop_content_position_image",
          "label": "Desktop Content Position",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-center"
        },
        {
          "type": "select",
          "id": "mobile_content_position_image",
          "label": "Mobile Content Position",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-center"
        },
        {
          "type": "text",
          "label": "Heading",
          "id": "image_heading"
        },
        {
          "type": "html",
          "label": "Sub Heading",
          "id": "image_sub_heading"
        },
        {
          "type": "html",
          "label": "Content",
          "id": "image_content"
        },
        {
          "type": "text",
          "label": "Button Text",
          "id": "image_button_text"
        },
        {
          "type": "url",
          "label": "Button URL",
          "id": "image_button_url"
        },
        {
          "type": "checkbox",
          "label": "External Link",
          "id": "image_external_link",
          "default": false
        },
        {
          "type": "range",
          "label": "Overlay",
          "id": "image_overlay",
          "default": 11,
          "min": 1,
          "max": 100,
          "step": 1
        }
      ]
    },
    {
      "type": "video_block",
      "name": "Video Block",
      "settings": [
        {
          "type": "image_picker",
          "label": "Poster",
          "id": "poster",
          "info": "2800 x 1000px .jpg recommended"
        },
        {
          "type": "video",
          "label": "Video",
          "id": "video"
        },
        {
          "type": "select",
          "id": "desktop_content_position_video",
          "label": "Desktop Content Position",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-center"
        },
        {
          "type": "select",
          "id": "mobile_content_position_video",
          "label": "Mobile Content Position",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-center"
        },
        {
          "type": "text",
          "label": "Heading",
          "id": "video_heading"
        },
        {
          "type": "html",
          "label": "Sub Heading",
          "id": "video_sub_heading"
        },
        {
          "type": "html",
          "label": "Content",
          "id": "video_content"
        },
        {
          "type": "text",
          "label": "Button Text",
          "id": "video_button_text"
        },
        {
          "type": "url",
          "label": "Button URL",
          "id": "video_button_url"
        },
        {
          "type": "checkbox",
          "label": "External Link",
          "id": "video_external_link",
          "default": false
        },
        {
          "type": "range",
          "label": "Overlay",
          "id": "video_overlay",
          "default": 11,
          "min": 1,
          "max": 100,
          "step": 1
        }
      ]
    },
    {
      "type": "marquee_products",
      "name": "Marquee Products",
      "settings": [
        {
          "type": "collection",
          "label": "Marquee collection",
          "id": "marquee_collection",
          "info": "Images of product will be selected from the collection which is selected here."
        },
        {
          "type": "text",
          "label": "Heading",
          "id": "heading"
        },
        {
          "type": "html",
          "label": "SubHeading",
          "id": "subheading"
        },
        {
          "type": "html",
          "label": "Content",
          "id": "content"
        },
        {
          "type": "text",
          "label": "Button Text",
          "id": "button_text"
        },
        {
          "type": "url",
          "label": "Button URL",
          "id": "button_url"
        },
        {
          "type": "checkbox",
          "label": "External Link",
          "id": "external_link",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow"
    }
  ]
}
{% endschema %}