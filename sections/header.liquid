<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<style>
  @media screen and (max-width: 425px) {
    .header_heading-logo-wrapper img {
      width: {{ settings.mobile_logo_width }}px;
      height: auto;
    }
  }
</style>
{%- if section.settings.menu_type_desktop == 'megamenu' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
{{ 'header.css' | asset_url | stylesheet_tag }}
<{% if section.settings.sticky_header_type != 'none' %}sticky-header data-sticky-type="{{ section.settings.sticky_header_type }}"{% else %}div{% endif %} class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}">
  <header class="header header--{{ section.settings.logo_position }} page-width ctm_{{ section.settings.menu_type_desktop }}">
    
    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header_heading_link">
        {%- if settings.logo != blank -%}
          <div class="header_heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{ settings.logo | image_url: width: 600 | image_tag:
              class: 'header_heading-logo',
              widths: widths,
              height: logo_height,
              width: settings.logo_width,
              alt: logo_alt,
              sizes: sizes,
              preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    {%- liquid
      if section.settings.menu != blank
        if section.settings.menu_type_desktop == 'dropdown'
          if section.settings.mobile_logo_position == 'click' 
            render 'header-dropdown-menu', class: 'click'
          else 
            render 'header-dropdown-menu', class: 'hover'
          endif
        elsif section.settings.menu_type_desktop != 'drawer'
          render 'header-mega-menu'       
        endif   
      endif
    %}

    {%- if section.settings.logo_position == 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header_heading_link">
        {%- if settings.logo != blank -%}
          <div class="header_heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{ settings.logo | image_url: width: 600 | image_tag:
              class: 'header_heading-logo',
              widths: widths,
              height: logo_height,
              width: settings.logo_width,
              alt: logo_alt,
              sizes: sizes,
              preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    <div class="left-side-icons">
      {% if section.settings.show_account %}
        <a href="#" aria-label="account icon" class="header_icon focus_inset login_popup">
          <div class="account">
            {%- render 'icon-account' -%}
          </div>
        </a>
      {% endif %}
      {% if section.settings.show_search %}
        <div class="search">
          {% render 'icon-search' %}
        </div>
      {% endif %}
      {% if section.settings.show_cart %}
        <a aria-label="cart icon" href="#" class="header_icon focus_inset">
          <div class="cart">
            {%- render 'icon-cart' -%}
          </div>
        </a>
      {% endif %}
    </div>
  </header>
</div>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "settings": [
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        {
          "value": "none",
          "label": "t:sections.header.settings.sticky_header_type.options.none"
        },
        {
          "value": "on-scroll-up",
          "label": "t:sections.header.settings.sticky_header_type.options.on_scroll_up"
        },
        {
          "value": "always",
          "label": "t:sections.header.settings.sticky_header_type.options.always"
        },
        {
          "value": "reduce-logo-size",
          "label": "t:sections.header.settings.sticky_header_type.options.reduce_logo_size"
        }
      ],
      "default": "on-scroll-up",
      "label": "t:sections.header.settings.sticky_header_type.label"
    },
    {
      "type": "select",
      "id": "logo_position",
      "options": [
        {
          "value": "middle-left",
          "label": "t:sections.header.settings.logo_position.options.middle_left"
        },
        {
          "value": "middle-center",
          "label": "t:sections.header.settings.logo_position.options.middle_center"
        }
      ],
      "default": "middle-left",
      "label": "t:sections.header.settings.logo_position.label",
      "info": "t:sections.header.settings.logo_position.info"
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "options": [
        {
          "value": "dropdown",
          "label": "t:sections.header.settings.menu_type_desktop.options.dropdown"
        },
        {
          "value": "megamenu",
          "label": "t:sections.header.settings.menu_type_desktop.options.megamenu"
        },
        {
          "value": "drawer",
          "label": "t:sections.header.settings.menu_type_desktop.options.drawer"
        }
      ],
      "default": "dropdown",
      "label": "t:sections.header.settings.menu_type_desktop.label",
      "info": "t:sections.header.settings.menu_type_desktop.info"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "mobile_logo_position",
      "options": [
        {
          "value": "click",
          "label": "t:sections.header.settings.mobile_logo_position.options.click"
        },
        {
          "value": "hover",
          "label": "t:sections.header.settings.mobile_logo_position.options.hover"
        }
      ],
      "default": "click",
      "label": "t:sections.header.settings.mobile_logo_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.utilities"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "default": true,
      "label": "t:sections.header.settings.show_account"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "default": true,
      "label": "t:sections.header.settings.show_search"
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "default": true,
      "label": "t:sections.header.settings.show_cart"
    }
  ],
  "blocks": [
    {
      "type": "logo_image",
      "name": "t:sections.header.blocks.logo_image.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "menu_enable",
          "label": "t:sections.header.blocks.logo_image.settings.menu_enable",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.header.blocks.logo_image.settings.image"
        },
        {
          "type": "text",
          "id": "mega_link",
          "label": "t:sections.header.blocks.logo_image.settings.mega_link",
          "default": "1"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.header.blocks.logo_image.settings.link"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.header.blocks.logo_image.settings.title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "t:sections.header.blocks.logo_image.settings.subtitle"
        }
      ]
    }
  ]
}
{% endschema %}
